{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "processing-service-route": {
        "ClusterId": "processing-cluster",
        "Match": {
          "Path": "/api/ledger/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "processing-cluster": {
        "Destinations": {
          "http-destination": {
            "Address": "http://localhost:5201"
          },
          "https-destination": {
            "Address": "https://localhost:7198"
          }
        }
      }
    }
  }
}
